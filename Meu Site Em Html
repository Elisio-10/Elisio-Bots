<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MozChats - Chat em Tempo Real</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        * { font-family: 'Inter', sans-serif; }
        .chat-bubble { animation: slideIn 0.3s ease-out; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-50 to-purple-50 min-h-screen">
    <div class="max-w-4xl mx-auto p-6">
        <!-- Header -->
        <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-xl border border-white/50 p-8 mb-8">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-comments text-white text-xl"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                            MozChats
                        </h1>
                        <p class="text-gray-600">Chat em tempo real • Anônimo • Seguro</p>
                    </div>
                </div>
                <div class="flex space-x-2">
                    <button id="themeToggle" class="p-2 rounded-xl bg-gray-100 hover:bg-gray-200 transition-all">
                        <i class="fas fa-moon text-gray-600"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">
            <!-- Chat Rooms -->
            <div class="lg:col-span-1">
                <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-xl border border-white/50 p-6 h-[500px]">
                    <h2 class="text-xl font-semibold mb-4 flex items-center"><i class="fas fa-list mr-2 text-indigo-500"></i>Salas</h2>
                    <div id="roomsList" class="space-y-2 max-h-[400px] overflow-y-auto">
                        <div class="room-item p-3 bg-indigo-50 rounded-xl cursor-pointer hover:bg-indigo-100 transition-all flex items-center space-x-3" data-room="geral">
                            <div class="w-10 h-10 bg-indigo-500 rounded-lg flex items-center justify-center text-white font-semibold">#geral</div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-900 truncate">#geral</p>
                                <p class="text-sm text-gray-500">245 online</p>
                            </div>
                            <div class="w-6 h-6 bg-green-500 rounded-full"></div>
                        </div>
                        <div class="room-item p-3 bg-purple-50 rounded-xl cursor-pointer hover:bg-purple-100 transition-all flex items-center space-x-3" data-room="crypto">
                            <div class="w-10 h-10 bg-purple-500 rounded-lg flex items-center justify-center text-white font-semibold">#crypto</div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-900 truncate">#crypto</p>
                                <p class="text-sm text-gray-500">89 online</p>
                            </div>
                            <div class="w-6 h-6 bg-green-400 rounded-full"></div>
                        </div>
                        <div class="room-item p-3 bg-emerald-50 rounded-xl cursor-pointer hover:bg-emerald-100 transition-all flex items-center space-x-3" data-room="tech">
                            <div class="w-10 h-10 bg-emerald-500 rounded-lg flex items-center justify-center text-white font-semibold">#tech</div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-900 truncate">#tech</p>
                                <p class="text-sm text-gray-500">156 online</p>
                            </div>
                            <div class="w-6 h-6 bg-green-500 rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chat Principal -->
            <div class="lg:col-span-2">
                <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-xl border border-white/50 h-[500px] flex flex-col">
                    <!-- Chat Header -->
                    <div class="p-6 border-b border-gray-100">
                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center text-white font-bold">#geral</div>
                            <div>
                                <p class="font-semibold text-gray-900">Sala Geral</p>
                                <p class="text-sm text-gray-500">245 membros online</p>
                            </div>
                            <div class="ml-auto flex space-x-2">
                                <button class="p-2 text-gray-500 hover:text-indigo-500 transition-all"><i class="fas fa-user-plus"></i></button>
                                <button class="p-2 text-gray-500 hover:text-indigo-500 transition-all"><i class="fas fa-volume-mute"></i></button>
                            </div>
                        </div>
                    </div>

                    <!-- Mensagens -->
                    <div id="messagesContainer" class="flex-1 p-6 overflow-y-auto space-y-4 bg-gradient-to-b from-white to-gray-50">
                        <div class="chat-bubble flex space-x-3">
                            <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-blue-600 rounded-xl flex items-center justify-center text-white font-semibold text-sm">JP</div>
                            <div class="flex-1">
                                <div class="flex items-center space-x-2 mb-1">
                                    <span class="font-semibold text-gray-900 text-sm">João P.</span>
                                    <span class="text-xs text-gray-500">• agora</span>
                                </div>
                                <p class="text-gray-800">Bem-vindo ao MozChats! 🚀<br>Chat anônimo e em tempo real.</p>
                            </div>
                        </div>
                        <!-- Mais mensagens serão adicionadas via JS -->
                    </div>

                    <!-- Input -->
                    <div class="p-6 border-t border-gray-100">
                        <div class="flex space-x-3">
                            <div class="flex-1 relative">
                                <input id="messageInput" type="text" placeholder="Digite sua mensagem..." 
                                       class="w-full p-4 pr-12 rounded-2xl border-2 border-gray-200 focus:border-indigo-500 focus:outline-none transition-all bg-white/50 backdrop-blur-sm">
                                <button id="emojiBtn" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-indigo-500 transition-all">
                                    <i class="fas fa-face-smile text-xl"></i>
                                </button>
                            </div>
                            <button id="sendBtn" class="w-12 h-12 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white rounded-2xl flex items-center justify-center shadow-lg hover:shadow-xl transition-all">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Online -->
        <div class="mt-8 p-6 bg-white/60 backdrop-blur-xl rounded-2xl border border-white/50">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-green-500 rounded-full"></div>
                    <span class="font-semibold text-gray-900">Online agora</span>
                </div>
                <div class="text-sm text-gray-500">245 pessoas</div>
            </div>
        </div>
    </div>

    <script>
        // Chat Functionality
        const roomsList = document.querySelectorAll('.room-item');
        const messagesContainer = document.getElementById('messagesContainer');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const currentRoom = document.querySelector('.room-item[data-room="geral"]');

        // Select room
        roomsList.forEach(room => {
            room.addEventListener('click', () => {
                roomsList.forEach(r => r.classList.remove('bg-indigo-100', 'ring-2', 'ring-indigo-500'));
                room.classList.add('bg-indigo-100', 'ring-2', 'ring-indigo-500');
            });
        });

        // Send message
        function sendMessage() {
            const text = messageInput.value.trim();
            if (!text) return;

            // Add message to chat
            const messageDiv = document.createElement('div');
            messageDiv.className = 'chat-bubble flex space-x-3';
            messageDiv.innerHTML = `
                <div class="w-10 h-10 bg-gradient-to-r from-green-500 to-emerald-600 rounded-xl flex items-center justify-center text-white font-semibold text-sm">EU</div>
                <div class="flex-1">
                    <div class="flex items-center space-x-2 mb-1">
                        <span class="font-semibold text-gray-900 text-sm">Você</span>
                        <span class="text-xs text-gray-500">• agora</span>
                    </div>
                    <p class="text-gray-800">${text}</p>
                </div>
            `;
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            messageInput.value = '';
        }

        sendBtn.addEventListener('click', sendMessage);
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Auto-scroll
        messagesContainer.scrollTop = messagesContainer.scrollHeight;

        // Theme toggle
        document.getElementById('themeToggle').addEventListener('click', () => {
            document.body.classList.toggle('dark');
        });

        // Simulate online users
        setInterval(() => {
            const users = ['Ana S.', 'Pedro M.', 'Lucas R.', 'Maria F.', 'João V.'];
            const randomUser = users[Math.floor(Math.random() * users.length)];
            console.log(`${randomUser} entrou na sala`);
        }, 10000);
    </script>
</body>
</html>
