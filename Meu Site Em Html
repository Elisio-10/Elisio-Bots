<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MozChats - Chat Rooms</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0f23 0%, #1a0033 50%, #0f0f23 100%);
            color: white; 
            min-height: 100vh; 
            overflow: hidden;
        }
        .container { max-width: 1400px; margin: 0 auto; height: calc(100vh - 80px); display: flex; flex-direction: column; }
        @media (min-width: 1024px) { .container { flex-direction: row; } }
        
        /* Header */
        header { 
            background: rgba(0,0,0,0.7); 
            backdrop-filter: blur(20px); 
            border-bottom: 1px solid rgba(168,85,247,0.3); 
            padding: 1rem; 
            position: sticky; 
            top: 0; z-index: 50;
        }
        .header-content { display: flex; justify-content: space-between; align-items: center; }
        .logo { display: flex; align-items: center; gap: 0.75rem; }
        .logo h1 { 
            font-size: 1.75rem; font-weight: 800; 
            background: linear-gradient(135deg, #a855f7, #ec4899); 
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; 
            background-clip: text;
        }
        .theme-toggle { 
            padding: 0.5rem; border-radius: 1rem; 
            background: rgba(0,0,0,0.4); 
            border: 1px solid rgba(168,85,247,0.3);
            cursor: pointer; transition: all 0.2s;
        }
        .theme-toggle:hover { background: rgba(0,0,0,0.6); }
        .status-dot { width: 0.5rem; height: 0.5rem; background: #10b981; border-radius: 50%; animation: pulse 3s infinite; }
        
        /* Sidebar */
        .sidebar { 
            width: 100%; height: 300px; 
            background: rgba(0,0,0,0.4); 
            backdrop-filter: blur(10px); 
            border-right: 1px solid rgba(168,85,247,0.2); 
            padding: 1.5rem; 
            overflow-y: auto;
        }
        @media (min-width: 1024px) { 
            .sidebar { width: 16rem; height: auto; } 
            .main-content { flex: 1; display: flex; flex-direction: column; }
        }
        .sidebar h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(168,85,247,0.3); }
        .room-btn { 
            width: 100%; display: flex; align-items: center; gap: 0.75rem; 
            padding: 0.75rem; border-radius: 1rem; 
            background: rgba(168,85,247,0.2); 
            border: 1px solid rgba(168,85,247,0.3);
            transition: all 0.2s; font-weight: 500;
        }
        .room-btn:hover { background: rgba(168,85,247,0.4); transform: translateX(4px); }
        .room-active { background: rgba(168,85,247,0.5) !important; box-shadow: 0 0 20px rgba(168,85,247,0.3); }
        .room-dot { width: 0.75rem; height: 0.75rem; background: #10b981; border-radius: 50%; }
        .room-count { margin-left: auto; font-size: 0.875rem; opacity: 0.75; }
        
        /* Messages */
        .messages-container { 
            flex: 1; padding: 1.5rem; 
            background: rgba(0,0,0,0.2); 
            backdrop-filter: blur(10px); 
            overflow-y: auto;
        }
        .welcome-screen { 
            height: 100%; display: flex; flex-direction: column; 
            align-items: center; justify-content: center; gap: 1rem; 
            opacity: 1; transition: opacity 0.3s;
        }
        .welcome-icon { 
            width: 6rem; height: 6rem; 
            background: linear-gradient(135deg, #a855f7, #ec4899); 
            border-radius: 1.5rem; display: flex; align-items: center; justify-content: center;
            animation: pulse 2s infinite;
        }
        .welcome-icon::before { content: "💬"; font-size: 2.5rem; }
        
        /* Input */
        .input-area { 
            padding: 1.5rem; 
            background: rgba(0,0,0,0.5); 
            backdrop-filter: blur(20px); 
            border-top: 1px solid rgba(168,85,247,0.2);
        }
        .input-container { max-width: 56rem; margin: 0 auto; }
        .message-input { 
            display: flex; gap: 0.75rem;
        }
        #messageInput { 
            flex: 1; background: rgba(0,0,0,0.6); 
            border: 1px solid rgba(168,85,247,0.4); 
            border-radius: 1.5rem; padding: 0.75rem 1.25rem; 
            color: white; font-size: 1rem;
            transition: all 0.2s;
        }
        #messageInput::placeholder { color: #9ca3af; }
        #messageInput:focus { outline: none; border-color: #a855f7; box-shadow: 0 0 20px rgba(168,85,247,0.3); }
        #sendBtn { 
            background: linear-gradient(135deg, #a855f7, #ec4899); 
            color: white; padding: 0.75rem 2rem; 
            border-radius: 1.5rem; font-weight: 600; 
            border: none; cursor: pointer; 
            transition: all 0.2s; box-shadow: 0 10px 30px rgba(168,85,247,0.4);
        }
        #sendBtn:hover { transform: translateY(-2px); box-shadow: 0 15px 40px rgba(168,85,247,0.6); }
        
        /* Message Bubble */
        .message-bubble { 
            animation: slideIn 0.4s ease-out; 
            opacity: 0; transform: translateX(20px);
        }
        @keyframes slideIn { to { opacity: 1; transform: translateX(0); } }
        .msg-container { display: flex; gap: 0.75rem; margin-bottom: 1.25rem; }
        .msg-avatar { 
            width: 2.5rem; height: 2.5rem; 
            background: linear-gradient(135deg, #a855f7, #ec4899); 
            border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; 
            font-weight: 700; font-size: 0.875rem; flex-shrink: 0;
        }
        .msg-content { flex: 1; min-width: 0; }
        .msg-header { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.25rem; }
        .msg-user { font-weight: 600; color: #c084fc; font-size: 0.875rem; }
        .msg-time { font-size: 0.75rem; color: #9ca3af; }
        .msg-text { 
            background: rgba(255,255,255,0.1); 
            backdrop-filter: blur(10px); 
            border-radius: 1rem; 
            padding: 0.75rem 1rem; 
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.2s;
        }
        .msg-text:hover { background: rgba(255,255,255,0.15); }
        
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .fade-out { opacity: 0 !important; }
    </style>
</head>
<body>
    <header>
        <div class="header-content max-w-6xl mx-auto">
            <div class="logo">
                <div style="width:1.5rem;height:1.5rem;background:linear-gradient(135deg,#a855f7,#ec4899);border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:1rem;">💬</div>
                <h1>MozChats</h1>
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <button id="themeToggle" class="theme-toggle" title="Alternar tema">🌙</button>
                <div class="status-dot"></div>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="sidebar">
            <h2>Salas</h2>
            <button class="room-btn room-active" data-room="geral">
                <div class="room-dot"></div>
                <span>#geral</span>
                <span class="room-count">(42)</span>
            </button>
            <button class="room-btn" data-room="crypto">
                <span>₿</span>
                <span>#crypto</span>
                <span class="room-count">(127)</span>
            </button>
            <button class="room-btn" data-room="tech">
                <span>💻</span>
                <span>#tech</span>
                <span class="room-count">(89)</span>
            </button>
        </div>

        <div class="main-content">
            <div id="messagesContainer" class="messages-container">
                <div id="welcomeScreen" class="welcome-screen">
                    <div class="welcome-icon"></div>
                    <h2>Bem-vindo ao MozChats!</h2>
                    <p style="max-width:28rem;color:#9ca3af;">Selecione uma sala para começar a conversar. Mensagens ficam salvas no navegador.</p>
                </div>
            </div>

            <div class="input-area">
                <div class="input-container">
                    <div class="message-input">
                        <input id="messageInput" type="text" placeholder="Digite sua mensagem... (Enter para enviar)" autocomplete="off">
                        <button id="sendBtn">➤ Enviar</button>
                    </div>
                    <div style="text-align:center;margin-top:0.5rem;font-size:0.75rem;color:#9ca3af;">
                        Enter para enviar • Shift+Enter para nova linha
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        class MozChats {
            constructor() {
                this.currentRoom = 'geral';
                this.messages = JSON.parse(localStorage.getItem('mozchats-messages') || '{}');
                this.init();
            }

            init() {
                this.bindEvents();
                this.loadRoom('geral');
            }

            bindEvents() {
                document.querySelectorAll('.room-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        document.querySelectorAll('.room-btn').forEach(b => b.classList.remove('room-active'));
                        e.currentTarget.classList.add('room-active');
                        this.currentRoom = e.currentTarget.dataset.room;
                        this.loadRoom(this.currentRoom);
                    });
                });

                const sendBtn = document.getElementById('sendBtn');
                const input = document.getElementById('messageInput');
                
                sendBtn.onclick = () => this.sendMessage();
                input.onkeypress = (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        this.sendMessage();
                    }
                };

                document.getElementById('themeToggle').onclick = () => {
                    document.body.classList.toggle('light');
                    localStorage.setItem('mozchats-theme', document.body.classList.contains('light') ? 'light' : 'dark');
                };

                if (localStorage.getItem('mozchats-theme') === 'light') {
                    document.body.classList.add('light');
                    document.getElementById('themeToggle').textContent = '☀️';
                }
            }

            loadRoom(room) {
                this.currentRoom = room;
                const roomMessages = this.messages[room] || [];
                const container = document.getElementById('messagesContainer');
                const welcomeScreen = document.getElementById('welcomeScreen');

                if (roomMessages.length === 0) {
                    welcomeScreen.classList.remove('fade-out');
                    return;
                }

                welcomeScreen.classList.add('fade-out');
                setTimeout(() => {
                    container.innerHTML = roomMessages.map(msg => this.formatMessage(msg)).join('') + 
                        '<div style="height:1rem;"></div>';
                    container.scrollTop = container.scrollHeight;
                }, 200);
            }

            sendMessage() {
                const input = document.getElementById('messageInput');
                const text = input.value.trim();
                if (!text) return;

                const message = {
                    id: Date.now(),
                    text: text.replace(/\n/g, '<br>'),
                    timestamp: new Date().toLocaleTimeString('pt-BR', {hour: '2-digit', minute: '2-digit'}),
                    user: ['MozUser', 'CryptoFan', 'TechNerd', 'TraderX', 'DevMaster', 'AnonChat'][Math.floor(Math.random() * 6)]
                };

                if (!this.messages[this.currentRoom]) this.messages[this.currentRoom] = [];
                this.messages[this.currentRoom].push(message);
                localStorage.setItem('mozchats-messages', JSON.stringify(this.messages));

                input.value = '';
                this.appendMessage(message);
            }

            appendMessage(message) {
                const container = document.getElementById('messagesContainer');
                const msgEl = document.createElement('div');
                msgEl.className = 'msg-container message-bubble';
                msgEl.innerHTML = this.formatMessage(message);
                container.appendChild(msgEl);
                container.scrollTop = container.scrollHeight;
            }

            formatMessage(msg) {
                return `
                    <div class="msg-container">
                        <div class="msg-avatar">${msg.user.charAt(0)}</div>
                        <div class="msg-content">
                            <div class="msg-header">
                                <span class="msg-user">${msg.user}</span>
                                <span class="msg-time">${msg.timestamp}</span>
                            </div>
                            <div class="msg-text">${msg.text}</div>
                        </div>
                    </div>
                `;
            }
        }

        new MozChats();
    </script>
</body>
</html>
